@app.route('/send', methods=['POST'])
def send():
    san_str = request.get_json().get('move', '').strip()
    if not san_str:
        return jsonify({'valid': False, 'message': 'No move provided'})

    # Convert any variant of castling to the standard Lucas format
    original_san = san_str

    # First, normalize the string for comparison
    normalized = san_str.upper().replace('0', 'O')

    # Handle queenside castling (O-O-O)
    if normalized in ['O-O-O', 'OOO']:
        san_str = 'O-O-O'
        print(f"Castling queenside detected: {original_san} -> {san_str}")
    # Handle kingside castling (O-O)
    elif normalized in ['O-O', 'OO']:
        san_str = 'O-O'
        print(f"Castling kingside detected: {original_san} -> {san_str}")

    success, msg, played_move, player = lucas.play_move(san_str)

    # Log what happened for debugging
    print(f"Move sent: {san_str}, Success: {success}, Message: {msg}")

    return jsonify({
        'valid': success,
        'message': msg,
        'move': played_move,
        'player': player
    })

