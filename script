# ----------------------------------------------------------------------
# Server-side Chess Logic (using python-chess)
# ----------------------------------------------------------------------
class ChessGame:
    def __init__(self):
        self.board = chess.Board()
        self.move_history = []  # list of {'move': san, 'player': 'white'/'black'}

    def reset(self):
        self.board.reset()
        self.move_history.clear()

    def make_move(self, san_str):
        """Try to make a move in SAN format. Returns (success, san_move, player, error_msg)"""
        try:
            # Clean up the move string
            san_str = san_str.strip()

            # Handle castling
            if san_str.lower() == 'o-o':
                san_str = 'O-O'
            elif san_str.lower() == 'o-o-o':
                san_str = 'O-O-O'

            # Parse the SAN move
            move = self.board.parse_san(san_str)

            # Double-check if move is legal
            if move not in self.board.legal_moves:
                return False, None, None, "Illegal move"

            # Get the normalized SAN representation
            san_move = self.board.san(move)

            # Determine player before moving
            player = 'white' if self.board.turn == chess.WHITE else 'black'

            # Apply move
            self.board.push(move)

            # Record
            self.move_history.append({
                'move': san_move,
                'player': player
            })

            return True, san_move, player, None

        except chess.IllegalMoveError:
            return False, None, None, "Illegal move"
        except chess.InvalidMoveError:
            return False, None, None, "Invalid move format"
        except chess.AmbiguousMoveError:
            return False, None, None, "Ambiguous move"
        except Exception as e:
            return False, None, None, str(e)

    def undo(self):
        """Undo last move. Returns (success, also_remove_flag, move_undone)"""
        if not self.move_history:
            return False, False, None

        last = self.move_history.pop()
        self.board.pop()

        # In Lucas, clicking Take Back removes both sides' last moves
        also_remove = False
        if self.move_history:
            # Also undo the previous move (opponent's) to match Lucas behaviour
            self.move_history.pop()
            self.board.pop()
            also_remove = True

        return True, also_remove, last['move']

    def current_fen(self):
        return self.board.fen()

    def get_history(self):
        return self.move_history


# ----------------------------------------------------------------------
# Lucas Chess Controller
# ----------------------------------------------------------------------
class LucasChessController:
    def __init__(self, chess_game):
        self.chess_game = chess_game
        self.lucas_path = self.find_lucas_chess()

    def find_lucas_chess(self):
        paths = [
            r"C:\Program Files\Lucas Chess\lucas.exe",
            r"C:\Program Files (x86)\Lucas Chess\lucas.exe",
            os.path.expanduser(r"~\AppData\Local\Programs\Lucas Chess\lucas.exe"),
        ]
        for path in paths:
            if os.path.exists(path):
                return path
        return None

    def focus_lucas(self):
        """Find Lucas Chess window, bring to front, and click center"""
        print("Looking for Lucas Chess window...")

        def callback(hwnd, windows):
            if win32gui.IsWindowVisible(hwnd):
                title = win32gui.GetWindowText(hwnd)
                # ONLY match if title contains exactly "Lucas Chess"
                if 'Lucas Chess' in title:
                    print(f"✅ Found Lucas Chess: '{title}'")
                    windows.append(hwnd)
            return True

        windows = []
        win32gui.EnumWindows(callback, windows)

        print(f"Lucas Chess windows found: {len(windows)}")

        if windows:
            hwnd = windows[0]
            title = win32gui.GetWindowText(hwnd)
            print(f"Focusing: {title}")

            # Restore if minimized
            if win32gui.IsIconic(hwnd):
                win32gui.ShowWindow(hwnd, win32con.SW_RESTORE)
                time.sleep(0.3)

            # Bring to foreground
            win32gui.SetForegroundWindow(hwnd)
            time.sleep(0.5)

            # Click center
            rect = win32gui.GetWindowRect(hwnd)
            center_x = (rect[0] + rect[2]) // 2
            center_y = (rect[1] + rect[3]) // 2
            pyautogui.click(center_x + 340, center_y)

            return True

        print("❌ No window with title 'Lucas Chess' found")
        return False

    def click_take_back(self):
        """Simply press backspace to undo a move"""
        if not self.focus_lucas():
            return False

        # Just press backspace once
        pyautogui.press('backspace')
        time.sleep(0.5)  # Give Lucas Chess time to process
        return True

    def play_move(self, san_str):
        # Log the move being attempted
        print(f"LucasController.play_move received: '{san_str}'")

        # First validate the move using chess_game
        success, san_move, player, error = self.chess_game.make_move(san_str)
        if not success:
            return False, error or f"Illegal move: {san_str}", None, None

        # Now send to Lucas Chess
        if not self.focus_lucas():
            return False, "Lucas Chess not found", san_move, player

        time.sleep(0.2)

        # Get window rectangle like in click_take_back
        windows = []
        win32gui.EnumWindows(lambda h, l: l.append(h) if (win32gui.IsWindowVisible(h) and (
                'Lucas' in win32gui.GetWindowText(h) or 'Chess' in win32gui.GetWindowText(h))) else True, windows)

        if windows:
            hwnd = windows[0]
            rect = win32gui.GetWindowRect(hwnd)
            x, y, w, h = rect

            # Handle castling moves - now using notation instead of mouse clicks
            if san_move == 'O-O':
                print("Sending kingside castling")
                # For white kingside castling: ke1g1
                # For black kingside castling: ke8g8
                if player == 'white':
                    pyautogui.write('ke1g1', interval=0.1)
                else:
                    pyautogui.write('ke8g8', interval=0.1)
                time.sleep(0.1)
                pyautogui.press('enter')

            elif san_move == 'O-O-O':
                print("Sending queenside castling")
                # For white queenside castling: ke1c1
                # For black queenside castling: ke8c8
                if player == 'white':
                    pyautogui.write('ke1c1', interval=0.1)
                else:
                    pyautogui.write('ke8c8', interval=0.1)
                time.sleep(0.1)
                pyautogui.press('enter')

        return True, f"Played: {san_move}", san_move, player

    def get_mouse_coords(self):
        """Print current mouse position - NO CLICKING"""
        if not self.focus_lucas():
            print("❌ Lucas Chess not found")
            return False

        print("\n🔍 MOUSE POSITION DISPLAY")
        print("Move your mouse over Lucas Chess window")
        print("Press Ctrl+C in terminal to stop\n")

        try:
            while True:
                x, y = pyautogui.position()
                print(f"\rMouse at: ({x}, {y})    ", end='', flush=True)
                time.sleep(0.1)
        except KeyboardInterrupt:
            print("\n\n👋 Stopped")
    def undo_last_move(self):
        success, also_remove, move_undone = self.chess_game.undo()
        if not success:
            return False, "No moves to undo", False

        if not self.focus_lucas():
            return False, "Lucas Chess not found", False

        if not self.click_take_back():
            return False, "Could not click Take Back", False

        return True, f"Undid: {move_undone}", also_remove


