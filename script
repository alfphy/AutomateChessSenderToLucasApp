@app.route('/send', methods=['POST'])
def send():
    data = request.get_json()
    uci_str = data.get('uci', '').strip()
    san_str = data.get('san', '').strip()

    if not uci_str:
        return jsonify({'valid': False, 'message': 'No UCI move provided'})

    success, msg, played_move, player = lucas.play_move(uci_str, san_str)

    # Log what happened for debugging
    print(f"UCI move sent: {uci_str}, Success: {success}, Message: {msg}")

    return jsonify({
        'valid': success,
        'message': msg,
        'move': played_move,
        'player': player
    })


@app.route('/undo', methods=['POST'])
def undo():
    success, msg, also_remove = lucas.undo_last_move()
    return jsonify({
        'success': success,
        'message': msg,
        'also_remove': also_remove
    })


