@app.route('/send', methods=['POST'])
def send():
    san_str = request.get_json().get('move', '').strip()
    if not san_str:
        return jsonify({'valid': False, 'message': 'No move provided'})

    success, msg, played_move, player = lucas.play_move(san_str)
    return jsonify({
        'valid': success,
        'message': msg,
        'move': played_move,
        'player': player  # Always defined on success
    })


@app.route('/undo', methods=['POST'])
def undo():
    success, msg, also_remove = lucas.undo_last_move()
    return jsonify({
        'success': success,
        'message': msg,
        'also_remove': also_remove
    })


@app.route('/focus', methods=['POST'])
def focus():
    success = lucas.focus_lucas()
    if success:
        return jsonify({'success': True, 'message': 'Lucas Chess focused'})
    else:
        return jsonify({'success': False, 'message': 'Lucas Chess window not found'})


def get_ip():
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80))
        ip = s.getsockname()[0]
        s.close()
        return ip
    except:
        return "192.168.1.xxx"


