# ----------------------------------------------------------------------
# Server-side Chess Logic (using python-chess)
# ----------------------------------------------------------------------
class ChessGame:
    def __init__(self):
        self.board = chess.Board()
        self.move_history = []  # list of {'move': san, 'player': 'white'/'black'}

    def reset(self):
        self.board.reset()
        self.move_history.clear()

    def make_move_from_uci(self, uci_str, san_str=None):
        """Try to make a move in UCI format. Returns (success, san_move, player, error_msg)"""
        try:
            # Clean up the UCI string
            uci_str = uci_str.strip().lower()
            print(f"Processing UCI move: '{uci_str}'")

            # Handle case where we get 'e4' instead of 'e2e4'
            if len(uci_str) == 2 and uci_str[0] in 'abcdefgh' and uci_str[1] in '12345678':
                # This is just a target square - we need to figure out the from square
                # For pawn moves, we can try to determine based on whose turn it is
                target_square = uci_str
                print(f"Received short notation: {target_square}, trying to determine from square")

                if self.board.turn == chess.WHITE:
                    # Try from the row below
                    from_square = target_square[0] + '2'
                    uci_str = from_square + target_square
                else:
                    # Try from the row above
                    from_square = target_square[0] + '7'
                    uci_str = from_square + target_square
                print(f"Converted to UCI: {uci_str}")

            # Handle castling
            if uci_str in ['o-o', '0-0']:
                if self.board.turn == chess.WHITE:
                    uci_str = 'e1g1'
                else:
                    uci_str = 'e8g8'
            elif uci_str in ['o-o-o', '0-0-0']:
                if self.board.turn == chess.WHITE:
                    uci_str = 'e1c1'
                else:
                    uci_str = 'e8c8'

            print(f"Final UCI to process: '{uci_str}'")

            # Parse UCI move
            from_square = chess.parse_square(uci_str[0:2])
            to_square = chess.parse_square(uci_str[2:4])

            # Check for promotion
            promotion = None
            if len(uci_str) >= 5:
                promotion_map = {'q': chess.QUEEN, 'r': chess.ROOK, 'b': chess.BISHOP, 'n': chess.KNIGHT}
                promotion = promotion_map.get(uci_str[4])

            # Create the move
            move = chess.Move(from_square, to_square, promotion=promotion)

            # Check if move is legal
            if move not in self.board.legal_moves:
                print(f"Move {move} not in legal moves list")
                # Try to find a matching pawn move
                if len(uci_str) == 4 and uci_str[0] in 'abcdefgh' and uci_str[1] in '27' and uci_str[
                    2] in 'abcdefgh' and uci_str[3] in '34':
                    # This might be a pawn double move - let's try to find it in legal moves
                    for legal_move in self.board.legal_moves:
                        if legal_move.from_square == from_square and legal_move.to_square == to_square:
                            move = legal_move
                            print(f"Found matching legal move: {move}")
                            break
                    else:
                        return False, None, None, "Illegal move"
                else:
                    return False, None, None, "Illegal move"

            # Get the SAN representation for display
            if san_str:
                san_move = san_str
            else:
                san_move = self.board.san(move)

            # Determine player before moving
            player = 'white' if self.board.turn == chess.WHITE else 'black'

            # Apply move
            self.board.push(move)

            # Record
            self.move_history.append({
                'move': san_move,
                'player': player
            })

            return True, san_move, player, None

        except Exception as e:
            print(f"Error processing move: {e}")
            import traceback
            traceback.print_exc()
            return False, None, None, str(e)

    def undo(self):
        """Undo last move. Returns (success, also_remove_flag, move_undone)"""
        if not self.move_history:
            return False, False, None

        last = self.move_history.pop()
        self.board.pop()

        # In Lucas, clicking Take Back removes both sides' last moves
        also_remove = False
        if self.move_history:
            # Also undo the previous move (opponent's) to match Lucas behaviour
            self.move_history.pop()
            self.board.pop()
            also_remove = True

        return True, also_remove, last['move']

    def current_fen(self):
        return self.board.fen()

    def get_history(self):
        return self.move_history


