        return jsonify({'valid': False, 'message': 'No move provided'})

    success, msg, played_move, player = lucas.play_move(san_str)
    return jsonify({
        'valid': success,
        'message': msg,
        'move': played_move,
        'player': player  # This is already correct from the server!
    })

